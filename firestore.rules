rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /parties/{partyId} {
      // 任何人皆可讀取練功團資料
      allow read: if true;
      
      // 任何人皆可建立練功團，但初始狀態必須是招募中，且人數為 0
      allow create: if request.resource.data.status == '招募中'
                    && request.resource.data.expectedCount == 0
                    && request.resource.data.passwordHash is string;
      
      // 允許更新（在 Vue 前端進行密碼雜湊驗證後修改），確保伺服器與發起人 ID 不被竄改，且已結束/已關閉的招募不可再修改
      allow update: if resource.data.status != '已結束'
                    && resource.data.status != '已關閉'
                    && request.resource.data.server == resource.data.server
                    && request.resource.data.leaderId == resource.data.leaderId;
      
      // 允許刪除（在 Vue 前端進行密碼雜湊驗證後刪除）
      allow delete: if true;
    }
    
    // 允許所有人讀寫訂閱關係資料夾，以便註冊與取消 FCM Token
    match /party_subscriptions/{subId} {
      allow read, write: if true;
    }
    
    // 允許所有人讀寫全站通知 Token 資料夾
    match /global_tokens/{tokenId} {
      allow read, write: if true;
    }

    // 4. 好物分享集合安全性規則
    match /shares/{shareId} {
      allow read: if true;
      allow create: if request.resource.data.name is string
                    && request.resource.data.giverId is string
                    && request.resource.data.server in ['新東京', '新大阪']
                    && request.resource.data.type in ['武器', '防具', '飾品', '其他']
                    && request.resource.data.passwordHash is string
                    && request.resource.data.status == '分享中'
                    && request.resource.data.applicantCount == 0;
      allow update: if resource.data.status != '已完成'
                    && request.resource.data.giverId == resource.data.giverId
                    && request.resource.data.server == resource.data.server;
      allow delete: if false;
    }

    // 5. 申請紀錄集合安全性規則
    match /applications/{appId} {
      allow read: if true;
      allow create: if request.resource.data.userId is string
                    && request.resource.data.charId is string
                    && request.resource.data.itemId is string
                    && request.resource.data.status == '申請中';
      allow update: if request.resource.data.userId == resource.data.userId
                    && request.resource.data.itemId == resource.data.itemId;
      allow delete: if true;
    }

    // 6. 身分識別碼集合安全性規則
    match /identities/{userId} {
      allow read: if true;
      allow create: if request.resource.data.charId is string
                    && request.resource.data.charId.size() > 0;
      allow update, delete: if false;
    }
  }
}
